# ===========================================
# AI Video Platform - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# App
DEBUG=true

# Database
# SQLite (local dev, no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./data/ai_video_platform.db
# PostgreSQL (production / Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_video_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_UPLOAD_SIZE_MB=100

# Worker
WORKER_CONCURRENCY=1
JOB_TIMEOUT_SECONDS=600

# Model directory (where HuggingFace models are cached)
MODELS_DIR=models
